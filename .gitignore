# =============================================================================
# ABA .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Cluster working directories (created by 'aba cluster --name X')
# Auto-maintained by build/release.sh Step 0
# -----------------------------------------------------------------------------
/sno*/
/demo*/
/mesh*/
/compact*/
/standard*/
/ocp/
/sno1-ext/
/sno2-ext/

# -----------------------------------------------------------------------------
# ABA runtime state
# -----------------------------------------------------------------------------
aba.conf*
.aba.conf.seen
target-ocp-version.conf
vmware.conf
vmware.conf.bk
kvm.conf
mirror.conf
*.ssh.conf
.index
.index-test/
.index-backup/

# -----------------------------------------------------------------------------
# mirror/ directory (generated/downloaded content)
# -----------------------------------------------------------------------------
mirror/aba.conf
mirror/*.sha256
mirror/.dnf-install.log
mirror/execution-environment.tar
mirror/image-archive.tar
mirror/imageset-config*yaml
mirror/.initialized
mirror/.available
mirror/.unavailable
mirror/.synced
mirror/mirror-registry
mirror/mirror-registry.tar.gz
mirror/mirror-registry-amd64.tar.gz
mirror/.oc-mirror.log
mirror/oc-mirror-workspace
mirror/pause.tar
mirror/postgres.tar
mirror/quay.tar
mirror/redis.tar
mirror/sqlite3.tar
mirror/regcreds
mirror/regcreds.bk
mirror/.registry-creds.txt
mirror/.rpms
mirror/data
mirror/scripts
mirror/templates
mirror/*.sh
mirror/.*
mirror/.??*
mirror/.redhat-operator-index*
mirror/mirror.conf*
mirror/docker-reg-image.tgz
mirror/quay-ng-image.tgz
mirror/cli
mirror/mirror
mirror/reg-uninstall.sh.provision

# -----------------------------------------------------------------------------
# cli/ directory (downloaded binaries)
# -----------------------------------------------------------------------------
cli/.init
cli/*tar.gz
cli/butane-binary
cli/butane-amd64
cli/*-download
cli/govc
cli/.*installed
cli/*.sha256
cli/scripts
cli/.tmp.*
cli/.*.tmp
cli/.??*

# -----------------------------------------------------------------------------
# test/ directory
# -----------------------------------------------------------------------------
test/mirror-registry.tar.gz
test/.ssh.conf
test/test.log*
test/output.log
test/mesh
test/?-stage
test/docker-reg/certs
test/docker-reg/data
test/docker-reg/auth
test/func/screenshots/
test/e2e/LAB-NETWORK.md
test/e2e/SESSION-NOTES.md
test/e2e/.config.env.deploy
test/e2e/.e2e-last-run
test/e2e/.pool-os/
test/e2e/logs/
e2e-parallel.log.*

# -----------------------------------------------------------------------------
# templates/ (generated operator sets)
# -----------------------------------------------------------------------------
templates/operator-set-abatest
templates/operator-set-custom-[0-9]*

# -----------------------------------------------------------------------------
# bundles/
# -----------------------------------------------------------------------------
bundles/work
bundles/v2/build.log
bundles/v2/work

# -----------------------------------------------------------------------------
# rpms/
# -----------------------------------------------------------------------------
rpms/*.rpm

# -----------------------------------------------------------------------------
# ai/ directory (session artifacts, never tracked)
# -----------------------------------------------------------------------------
ai/

# -----------------------------------------------------------------------------
# Editor / IDE / tooling
# -----------------------------------------------------------------------------
.vscode*
#.cursor/
.planning/
.cursorignore
# Ignore Cursor Plan Mode drafts and local temp states
.cursor/plans/
.cursor/skills/

# -----------------------------------------------------------------------------
# General patterns
# -----------------------------------------------------------------------------
*.md.bak
*.bak
.backup/
.bundle
.??*.log
*/*sha256sum.txt
*/cluster.conf
xxx/
