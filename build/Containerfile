# ABA container image — packages the ABA repo + all required RPMs so that
# ABA can run on a disconnected bastion without any dnf/yum access.
#
# BUILD (on the connected side, after 'aba bundle --repo'):
#   podman build -t aba:latest -f build/Containerfile .
#
# The build context is the ABA repo root.  The bundle tar is NOT used
# directly; instead we COPY the live repo tree, which keeps the
# Containerfile independent of bundle naming.
#
# Image-set archives (mirror_*.tar) are intentionally excluded —
# mount them at runtime to avoid multi-GB image layers.

FROM registry.access.redhat.com/ubi9/ubi:latest

ARG ABA_USER=aba
ARG ABA_UID=1000

# All RPMs ABA needs on an internal (disconnected) bastion,
# plus openssh-clients for the "remote to localhost" registry install.
# git is included so ./install can run its version-check logic.
RUN dnf install -y \
	sudo \
	make jq git \
	python3 python3-jinja2 python3-pyyaml \
	ncurses which dialog file hostname diffutils \
	bind-utils nmstate net-tools \
	skopeo openssl coreos-installer \
	httpd acl polkit \
	openssh-clients \
	&& dnf clean all \
	&& rm -rf /var/cache/dnf

# Create a non-root user whose UID matches the host user so that
# bind-mounted volumes (~/.aba, ~/.ssh, mirror/data) are accessible.
RUN useradd -m -s /bin/bash -u ${ABA_UID} ${ABA_USER} \
	&& mkdir -p /etc/sudoers.d \
	&& echo "${ABA_USER} ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/${ABA_USER}

# Copy the ABA repo into the image (excludes mirror data, .git, etc. via .containerignore)
COPY --chown=${ABA_USER}:${ABA_USER} . /home/${ABA_USER}/aba

USER ${ABA_USER}
WORKDIR /home/${ABA_USER}/aba

# Create mount-point directories excluded by .containerignore
RUN mkdir -p mirror/data mirror/regcreds cli

# Pre-run install so 'aba' is on PATH when the container starts
RUN ./install

ENV PATH="/home/${ABA_USER}/bin:${PATH}"

# Default: drop into a shell so the user can run 'aba' interactively
CMD ["bash"]
