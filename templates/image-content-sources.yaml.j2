# oc-mirror generates the actual IDMS/ITMS; this template is used as a fallback.
- mirrors:
  - {{ reg_host }}:{{ reg_port }}{{ reg_path }}/openshift/release
  source: quay.io/openshift-release-dev/ocp-v{{ ocp_major }}.0-art-dev
- mirrors:
  - {{ reg_host }}:{{ reg_port }}{{ reg_path }}/openshift/release-images
  source: quay.io/openshift-release-dev/ocp-release
