# ABA User Configuration (~/.aba/config)
# This file is copied to ~/.aba/config during installation.
# Settings here affect ABA behavior system-wide for this user.
# Uncomment and adjust values as needed.

# --- Catalog Index Settings ---
# All timeout/TTL values accept duration strings: 30s, 20m, 12h, 1d (or bare seconds).

# Cache TTL for downloaded operator catalog indexes (default: 12h).
# Indexes are re-downloaded when older than this value.
# Increase for stable environments; decrease if upstream catalog changes cause oc-mirror errors.
CATALOG_CACHE_TTL=12h

# Download timeout for catalog index downloads (default: 20m).
# This controls how long 'aba' waits for the operator index files (.index/*) to download.
# Increase for slow networks. Not related to oc-mirror image mirroring (see OC_MIRROR_IMAGE_TIMEOUT).
CATALOG_INDEX_DOWNLOAD_TIMEOUT=20m

# Max concurrent catalog downloads (default: 3 = all three catalogs in parallel).
# Set to 1 for sequential downloads on constrained systems.
# CATALOG_MAX_PARALLEL=3

# --- oc-mirror Settings ---

# oc-mirror --image-timeout value (default: 30m).
# Increase for slow networks or large operator images.
# OC_MIRROR_IMAGE_TIMEOUT=30m

# oc-mirror --parallel-images value (default: 8).
# Number of images to mirror concurrently. Reduce on slow or unreliable networks.
# OC_MIRROR_PARALLEL_IMAGES=8

# Extra flags appended to every oc-mirror invocation (sync, save, load).
# Sigstore signature handling is managed by
# $HOME/.config/containers/registries.d/aba-sigstore.yaml
# (installed automatically by ABA).
# OC_MIRROR_FLAGS="--remove-signatures=true"
